#include <iostream>
#include <vector>
#include <string>
using namespace std;

int main()
{
    vector<string> cards;
    vector<string> pins;

    cards.push_back("4532123412341234");
    pins.push_back("1234");

    string inputCard;
    string inputPin;

    cout<<"Insert card: ";
    cin>>inputCard;

    int found=-1;

    for(int i=0;i<cards.size();i++)
    {
        if(cards[i]==inputCard)
        {
            found=i;
        }
    }

    if(found==-1)
    {
        cout<<"Card not found\n";
        return 0;
    }

    cout<<"Enter pin: ";
    cin>>inputPin;

    if(inputPin==pins[found])
        cout<<"Access granted\n";
    else
        cout<<"Wrong pin\n";
}
